#!/bin/sh
":"; exec emacs --script "$0" -- "$@" # -*- mode: emacs-lisp; lexical-binding: t -*-
;;; bin/gitq --- standalone CLI for the GitQ pipeline language

;; Locate git-branch-off-gitq.el relative to this script (../git-branch-off-gitq.el).
;; Set GITQ_LIB to an absolute path to override.
(let* ((self    (or load-file-name buffer-file-name ""))
       (lib-dir (or (getenv "GITQ_LIB")
                    (expand-file-name ".." (file-name-directory
                                            (file-truename self)))))
       (lib     (expand-file-name "git-branch-off-gitq" lib-dir)))
  (unless (file-readable-p (concat lib ".el"))
    (message "gitq: cannot find git-branch-off-gitq.el (checked %s.el)" lib)
    (message "gitq: set GITQ_LIB=/path/to/dir to override")
    (kill-emacs 1))
  (add-to-list 'load-path lib-dir)
  (load lib nil t))

;;; Plain-text output for terminal use

(defun gitq--cli-frame-line (frame)
  "Return a plain-text rendering of FRAME for terminal output."
  (let ((type (plist-get frame :type)))
    (pcase type
      ('commit
       (let* ((sha   (or (plist-get frame :sha) "?"))
              (short (substring sha 0 (min 8 (length sha))))
              (auth  (or (plist-get frame :author) ""))
              (date  (or (plist-get frame :date) ""))
              (msg   (or (plist-get frame :message) "")))
         (format "%s  %-20s  %s  %s"
                 short
                 (substring auth 0 (min 20 (length auth)))
                 (substring date 0 (min 10 (length date)))
                 msg)))
      ('ref
       (let* ((sha   (or (plist-get frame :sha) "?"))
              (short (substring sha 0 (min 8 (length sha)))))
         (format "%-40s  %s"
                 (or (plist-get frame :name) "?")
                 short)))
      ('blob
       (or (plist-get frame :path) "?"))
      ('tree
       (format "(tree %s)" (or (plist-get frame :sha) "?")))
      ('worktree
       (format "%-40s  %s"
               (or (plist-get frame :path) "?")
               (or (plist-get frame :branch) "(detached)")))
      ('line
       (format "%s:%d: %s"
               (or (plist-get frame :path) "?")
               (or (plist-get frame :line-number) 0)
               (or (plist-get frame :content) "")))
      ('hunk
       (format "%s:%d-%d"
               (or (plist-get frame :path) "?")
               (or (plist-get frame :start-line) 0)
               (or (plist-get frame :end-line) 0)))
      (_
       ;; Projected or unknown — print key:value pairs
       (mapconcat (lambda (kv) (format "%s:%s" (car kv) (cdr kv)))
                  (cl-loop for (k v) on frame by #'cddr
                           collect (cons k v))
                  "  ")))))

(defun gitq--cli-display (frames pipeline-str)
  "Print FRAMES to stdout (overrides the Emacs-buffer display)."
  (if frames
      (dolist (f frames)
        (princ (gitq--cli-frame-line f))
        (terpri))
    (message "gitq: (no results) — %s" pipeline-str)))

;; Replace the Emacs-buffer display with plain stdout output.
(fset 'gitq--display #'gitq--cli-display)

;; count terminal: print to stdout rather than message (stderr in batch mode).
(defun gitq--cli-apply-terminal (frames node pipeline-str)
  "Terminal dispatcher with count redirected to stdout."
  (if (eq (plist-get node :op) 'count)
      (progn (princ (format "%d\n" (length frames))))
    (gitq--apply-terminal frames node pipeline-str)))

;;; Entry point

(defun gitq--cli-usage ()
  "Print usage to stderr."
  (message "Usage: gitq <pipeline>")
  (message "")
  (message "Examples:")
  (message "  gitq 'commits | take 10'")
  (message "  gitq 'commits | where .author contains \"alice\" | show'")
  (message "  gitq 'commits in main..HEAD | count'")
  (message "  gitq 'branches'")
  (message "  gitq 'HEAD | via .parent*  | where .message contains \"fix\"'")
  (message "")
  (message "Set GITQ_LIB=/dir to override the path to git-branch-off-gitq.el"))

(let ((args (seq-remove (lambda (a) (equal a "--")) command-line-args-left)))
  (setq command-line-args-left nil)
  (cond
   ((or (null args) (member (car args) '("-h" "--help")))
    (gitq--cli-usage)
    (kill-emacs (if args 0 1)))

   ;; --complete PREFIX  →  print completion candidates, one per line.
   ;; Used by the zsh _gitq function and the Emacs CAPF can call this too.
   ((equal (car args) "--complete")
    (condition-case _
        (let* ((default-directory (gitq--toplevel))
               (prefix   (mapconcat #'identity (cdr args) " "))
               (cands    (gitq--complete-candidates prefix)))
          (dolist (c cands) (princ c) (terpri)))
      (error nil))
    (kill-emacs 0))

   (t
    (let ((pipeline (mapconcat #'identity args " ")))
      (condition-case err
          (let* ((default-directory (gitq--toplevel))
                 (nodes    (gitq--parse-flat pipeline))
                 (src-node (car nodes))
                 (rest     (cdr nodes))
                 (last     (car (last rest)))
                 (is-term  (and last (eq (plist-get last :type) 'terminal)))
                 (steps    (if is-term (butlast rest) rest))
                 (terminal (when is-term last))
                 (frames   (gitq--exec-source src-node))
                 (result   (cl-reduce #'gitq--exec-step steps :initial-value frames)))
            (if terminal
                (gitq--cli-apply-terminal result terminal pipeline)
              (gitq--cli-display result pipeline)))
        (user-error
         (message "gitq: %s" (cadr err))
         (kill-emacs 1))
        (error
         (message "gitq: error: %s" (error-message-string err))
         (kill-emacs 1)))))))
